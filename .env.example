# --------------------
# Local development
# --------------------
# Copy to `.env` for local runs.
DJANGO_ENV=local

# Required
SECRET_KEY=change-me

# Local: 1/true enables debug and safer cookies disabled by `fitness.config.local`.
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional for local Postgres use. Leave empty to use SQLite (db.sqlite3).
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=disable
DATABASE_URL=

# Optional: used by `ai_engine` when you integrate OpenAI.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_SECONDS=45
# Cap JSON size (default 6144) — lower can speed up responses; raise if validation truncates output.
# OPENAI_MAX_OUTPUT_TOKENS=6144
# OPENAI_WORKOUT_MAX_ATTEMPTS=1

# --------------------
# Railway / production
# --------------------
# Railway should provide these environment variables at runtime.
# DJANGO_ENV=production
# DEBUG=0
# ALLOWED_HOSTS=YOUR_RAILWAY_DOMAIN
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# OPENAI_API_KEY=...

# If you have an alternate external origin for CSRF.
# CSRF_TRUSTED_ORIGINS=https://your-domain.com
